{
  "name": "octolab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:backend": "turbo run start --filter=@octolab/backend",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@octolab/frontend",
    "dev:backend": "turbo run dev --filter=@octolab/backend",
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@octolab/frontend",
    "build:backend": "turbo run build --filter=@octolab/backend",
    "build:domain": "turbo run build --filter=@octolab/domain",
    "lint": "turbo run lint",
    "lint:frontend": "turbo run lint --filter=@octolab/frontend",
    "lint:backend": "turbo run lint --filter=@octolab/backend",
    "lint:domain": "turbo run lint --filter=@octolab/domain"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@stylistic/eslint-plugin": "5.1.0",
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "eslint-config-prettier": "10.1.5",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.0.1",
    "eslint-plugin-jsdoc": "51.2.3",
    "eslint-plugin-no-secrets": "2.2.1",
    "eslint-plugin-optimize-regex": "1.2.1",
    "eslint-plugin-pii": "1.0.2",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-prettier": "5.5.1",
    "eslint-plugin-unused-imports": "4.1.4",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5",
    "typescript-eslint": "8.35.0"
  },
  "dependencies": {
    "uuid": "^11.1.0",
    "zod": "^4.0.5"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.0"
}
