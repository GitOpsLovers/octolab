{
  "name": "@octolab/backend",
  "version": "0.0.0",
  "scripts": {
    "start": "node --enable-source-maps dist/index.js",
    "dev": "nodemon --exec \"tsx --inspect src/index.ts\" -e ts",
    "prebuild": "tsc --noEmit",
    "build": "node esbuild.config.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@octolab/domain": "workspace:*",
    "@sentry/esbuild-plugin": "5.3.0",
    "@sentry/node": "10.53.1",
    "@supabase/supabase-js": "2.106.1",
    "auth0": "5.10.0",
    "body-parser": "2.2.2",
    "cors": "2.8.6",
    "date-fns": "4.3.0",
    "express": "5.2.1",
    "express-oauth2-jwt-bearer": "1.9.0",
    "helmet": "8.2.0",
    "http-status-codes": "2.3.0",
    "resend": "6.12.3",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@gitopslovers/eslint-config-multistack": "1.4.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "esbuild": "0.28.0",
    "eslint": "10.4.0",
    "nodemon": "3.1.14",
    "tsx": "4.22.3"
  }
}
